# Optional overrides for the systemd user service.
# Copy to ~/.config/voice/daemon.env and uncomment what you need.

# VOICE_SHORTCUT_BACKEND=auto
# VOICE_AUTO_PASTE=1
# VOICE_PASTE_TOOL=wtype
# VOICE_HOTKEY=Ctrl+Alt+space
# VOICE_LANGUAGE=en
# VOICE_WHISPER_MODEL=/home/you/.local/share/voice/models/whisper/ggml-base.en.bin
# VOICE_LLAMA_MODEL=/home/you/.local/share/voice/models/llama/model.gguf
